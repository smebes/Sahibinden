{
  "manifest_version": 3,
  "name": "FixParts Görüntüleme Botu",
  "version": "1.4.0",
  "description": "Sahibinden mağaza ilanları: link, genel, detay ve görüntüleme pipeline.",
  "permissions": ["tabs", "scripting", "storage", "alarms"],
  "host_permissions": [
    "https://*.sahibinden.com/*",
    "http://*.sahibinden.com/*",
    "http://127.0.0.1:3009/*",
    "http://51.102.128.78:3009/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "FixParts Görüntüleme"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
